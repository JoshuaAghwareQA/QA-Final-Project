  "item": [
    {
      "name": "Users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains users array\", function () {\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.users).to.be.an(\"array\");\r",
              "    pm.expect(response.users.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Each user has id, firstName and email\", function () {\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    response.users.forEach(function (user) {\r",
              "        pm.expect(user).to.have.property(\"id\");\r",
              "        pm.expect(user).to.have.property(\"firstName\");\r",
              "        pm.expect(user).to.have.property(\"email\");\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"First name matches the request\", function () {\r",
              "    const response = pm.response.json();\r",
              "    const request = JSON.parse(pm.request.body.raw);\r",
              "\r",
              "    pm.expect(response.firstName).to.eql(request.firstName);\r",
              "});\r",
              "\r",
              "pm.test(\"User ID is generated\", function () {\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.id).to.exist;\r",
              "    pm.expect(response.id).to.be.a(\"number\");\r",
              "    pm.expect(response.id).to.be.above(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
